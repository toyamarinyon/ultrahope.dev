{
	"name": "eslint-plugin-raula",
	"version": "0.0.1",
	"description": "Opinionated ESLint rules and flat-config presets for Tailwind and Next.js app standards.",
	"keywords": [
		"eslint",
		"eslintplugin",
		"eslint-plugin",
		"nextjs",
		"tailwindcss",
		"design-system"
	],
	"homepage": "https://github.com/toyamarinyon/journal.ultrahope.dev/tree/main/packages/eslint-plugin-raula",
	"bugs": {
		"url": "https://github.com/toyamarinyon/journal.ultrahope.dev/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/toyamarinyon/journal.ultrahope.dev.git",
		"directory": "packages/eslint-plugin-raula"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./tailwind": {
			"types": "./dist/tailwind.d.ts",
			"import": "./dist/tailwind.js",
			"default": "./dist/tailwind.js"
		},
		"./next-layout": {
			"types": "./dist/next-layout.d.ts",
			"import": "./dist/next-layout.js",
			"default": "./dist/next-layout.js"
		},
		"./css": {
			"types": "./dist/css.d.ts",
			"import": "./dist/css.js",
			"default": "./dist/css.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"prepublishOnly": "npm run build"
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"eslint": "^9"
	},
	"dependencies": {
		"tailwindcss": "^4"
	},
	"devDependencies": {
		"tsup": "^8.5.0",
		"typescript": "^5.9.3"
	}
}
